    "minPoopSize": 0.3,
    "maxPoopSize": 2.6,
    "defaultPoopSize": 1.0,
    "massiveAnnouncementThreshold": 2.0,
    "generationTiers": [
      { "chance": 40, "name": "Normal",        "minMultiplier": 0.9, "maxMultiplier": 1.1 },
      { "chance": 25, "name": "Above Average", "minMultiplier": 1.1, "maxMultiplier": 1.4 },
      { "chance": 15, "name": "Small",         "minMultiplier": 0.7, "maxMultiplier": 0.9 },
      { "chance": 10, "name": "Large",         "minMultiplier": 1.4, "maxMultiplier": 1.7 },
      { "chance": 5,  "name": "Tiny",          "minMultiplier": 0.5, "maxMultiplier": 0.7 },
      { "chance": 3,  "name": "Huge",          "minMultiplier": 1.7, "maxMultiplier": 2.0 },
      {
        "chance": 2, "name": "Rare", "minMultiplier": 2.0, "maxMultiplier": 2.6,
        "subTiers": [
          { "weight": 80, "name": "Massive",         "minRangePercent": 0.0,   "maxRangePercent": 0.833 },
          { "weight": 19, "name": "Legendary",       "minRangePercent": 0.833, "maxRangePercent": 1.0 },
          { "weight": 1,  "name": "Ultra Legendary", "minRangePercent": 0.98,  "maxRangePercent": 0.999 }
        ]
      }
    ],
    "sizeCategories": [
      { "threshold": 2.5, "localeKey": "size.legendary" },
      { "threshold": 2.0, "localeKey": "size.desc_massive" },
      { "threshold": 1.7, "localeKey": "size.desc_huge" },
      { "threshold": 1.4, "localeKey": "size.desc_large" },
      { "threshold": 1.1, "localeKey": "size.desc_above_average" },
      { "threshold": 0.9, "localeKey": "size.desc_normal" },
      { "threshold": 0.7, "localeKey": "size.desc_small" },
      { "threshold": 0.5, "localeKey": "size.desc_tiny" },
      { "threshold": 0.0, "localeKey": "size.desc_microscopic" }
    ]
  },
  "color": {
