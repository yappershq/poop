      { "localeKey": "color.brown_default", "red": 139, "green": 69,  "blue": 19 },
      { "localeKey": "color.white",         "red": 255, "green": 255, "blue": 255 },
      { "localeKey": "color.black",         "red": 0,   "green": 0,   "blue": 0 },
      { "localeKey": "color.red",           "red": 255, "green": 0,   "blue": 0 },
      { "localeKey": "color.green",         "red": 0,   "green": 255, "blue": 0 },
      { "localeKey": "color.blue",          "red": 0,   "green": 0,   "blue": 255 },
      { "localeKey": "color.yellow",        "red": 255, "green": 255, "blue": 0 },
      { "localeKey": "color.purple",        "red": 128, "green": 0,   "blue": 128 },
      { "localeKey": "color.orange",        "red": 255, "green": 165, "blue": 0 },
      { "localeKey": "color.pink",          "red": 255, "green": 105, "blue": 180 },
      { "localeKey": "color.cyan",          "red": 0,   "green": 255, "blue": 255 },
      { "localeKey": "color.gold",          "red": 255, "green": 215, "blue": 0 },
      { "localeKey": "color.lime",          "red": 0,   "green": 255, "blue": 0 },
      { "localeKey": "color.magenta",       "red": 255, "green": 0,   "blue": 255 },
      { "localeKey": "color.silver",        "red": 192, "green": 192, "blue": 192 },
