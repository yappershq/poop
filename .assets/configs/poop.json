  "sound": {
    "enableSounds": true,
    "soundVolume": 0.5,
    "enableTauntSounds": true,
    "poopSounds": [
      { "soundEvent": "poop.poop_sound_01" },
      { "soundEvent": "poop.poop_sound_02" },
      { "soundEvent": "poop.poop_sound_03", "volume": 0.7 }
    ],
    "tauntSounds": [
      { "soundEvent": "poop.poop_taunt_01" },
      { "soundEvent": "poop.poop_taunt_02" }
    ]
  },
  "victimDetection": {
    "maxDeadPlayerDistance": 500.0,
